{
  "name": "cybersuite",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"apps/**/*.{ts,tsx,md}\" \"services/**/*.{ts,tsx,md}\" \"packages/**/*.{ts,tsx,md}\" \"*.md\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": ">=18"
  },
  "version": "0.0.1"
}
